# OS files
.DS_Store
Thumbs.db

# Editor files
*.swp
*.swo
*~
.vscode/
.idea/

# Environment files
.env
.env.local
.env*.local

# Node modules (if any)
node_modules/

# Logs
*.log

# Credentials and secrets
**/credentials.json
**/token.json
**/sa-key.json
*.pem
*.key
# Service account key files (GCP downloads)
apps/*-analytics-*.json
apps/*-service-account-*.json

# GTM container exports (temp files)
apps/GTM-*.json

# gh CLI config (GH_CONFIG_DIR — stores OAuth token, must not be committed)
/workspace/.gh-config/

# Large data files that can be regenerated
data/archive/
data/secrets/
data/*.csv
n8n/local-files/

# Build outputs
apps/**/.next/
apps/data/
packages/db/dist/

# Claude Code session files
.claude/settings.local.json
.playwright-mcp/
