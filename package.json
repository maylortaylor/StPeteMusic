{
  "name": "stpetemusic",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "scripts": {
    "dev": "docker-compose -f docker-compose.dev.yml up -d && npm run dev --workspace=apps/web",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:cms": "npm run dev --workspace=apps/cms",
    "dev:services": "docker-compose -f docker-compose.dev.yml up -d",
    "dev:stop": "docker-compose -f docker-compose.dev.yml down",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "optionalDependencies": {
    "@esbuild/linux-x64": "0.28.0",
    "@img/sharp-libvips-linux-x64": "1.2.4",
    "@img/sharp-linux-x64": "0.34.5",
    "@next/swc-linux-x64-gnu": "16.2.4",
    "@rolldown/binding-linux-x64-gnu": "1.0.0-rc.17",
    "@rollup/rollup-linux-x64-gnu": "4.60.1",
    "@tailwindcss/oxide-linux-x64-gnu": "4.2.4",
    "@unrs/resolver-binding-linux-x64-gnu": "1.11.1",
    "lightningcss-linux-x64-gnu": "1.32.0"
  }
}
