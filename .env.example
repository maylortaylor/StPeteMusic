POSTGRES_PASSWORD=your_postgres_password_here
DB_ENCRYPTION_KEY=your_db_encryption_key

# LIST MONK newsletter
LISTMONK_ADMIN_USER=your_listmonk_admin_username
LISTMONK_ADMIN_PASSWORD=your_listmonk_admin_password
LISTMONK_LIST_ID=1
SES_SMTP_USERNAME=your_ses_smtp_username
SES_SMTP_PASSWORD=your_ses_smtp_password

# n8n API Configuration
N8N_API_KEY=your_n8n_api_key_here
N8N_VENUE_SYNC_WEBHOOK_URL=  # Webhook that triggers the venue data scrape workflow
N8N_ARTIST_ENRICHMENT_WEBHOOK_URL=  # Webhook that triggers the artist enrichment scrape workflow
N8N_WEBHOOK_SECRET=  # Shared secret for n8n → admin webhook callbacks (x-webhook-secret header)

# Admin app — Anthropic SDK (for newsletter blurb + blog post generation)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# n8n enrichment callback (set in n8n .env, not admin app)
# ADMIN_ENRICHMENT_CALLBACK_URL=https://admin.stpetemusic.live/api/webhooks/enrichment-complete

# Standalone artist enrichment (admin → n8n)
N8N_ARTIST_STANDALONE_ENRICHMENT_WEBHOOK_URL=  # https://n8n.stpetemusic.live/webhook/artist-standalone-enrichment
# Standalone artist enrichment callback — must also be in root .env AND passed via docker-compose.prod.yaml
ADMIN_ARTIST_ENRICHMENT_CALLBACK_URL=https://admin.stpetemusic.live/api/webhooks/artist-standalone-enrichment-complete

# S3 assets bucket for artist/media images
ASSETS_BUCKET=stpetemusic-assets
ASSETS_CDN_URL=https://cdn.stpetemusic.live

# Obsidian Local REST API
# Local dev:  http://host.docker.internal:27123
# Production: your Tailscale Mac IP, e.g. http://100.x.x.x:27123
OBSIDIAN_HOST=http://host.docker.internal:27123

# Claude API (for AI-powered features)
CLAUDE_API_KEY_N8N_STPETEMUSIC=your_claude_api_key_here
CLAUDE_API_KEY=your_claude_api_key_here

# Groq API (for LLM inference - CURRENTLY IN USE)
GROQ_API_KEY=your_groq_api_key_here

nDEEPSEEK_API_KEY=your_deepseek_api_key_here

# Google Gemini API (for AI caption generation)
N8N_GEMINI_API_KEY=your_gemini_api_key_here

# Instagram Business API
IG_USER_ID=your_instagram_business_account_id
IG_ACCESS_TOKEN=your_instagram_long_lived_access_token

# Facebook Page API
FB_PAGE_ID=your_facebook_page_id
FB_ACCESS_TOKEN=your_facebook_page_access_token

GOOGLE_CALENDAR_ID=suite.e.stpete@gmail.com

# Facebook App credentials — used for public page event scraping via Graph API.
# Find App ID + Secret in the Meta Developer Console under your existing Facebook App.
# One-time Page ID lookup: GET https://graph.facebook.com/v21.0/{username}?fields=id&access_token={FB_APP_ID}|{FB_APP_SECRET}
FB_APP_ID=your_facebook_app_id
FB_APP_SECRET=your_facebook_app_secret

# YouTube — admin app (OAuth2 for YouTube Data API v3)
YOUTUBE_OAUTH_CLIENT_ID=        # Google Cloud Console → OAuth 2.0 credentials → client ID
YOUTUBE_OAUTH_CLIENT_SECRET=    # Same credential → client secret
YOUTUBE_REFRESH_TOKEN=          # Run: node scripts/get-youtube-token.mjs
YOUTUBE_API_KEY=your_youtube_api_key
YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxx   # YouTube channel ID for @StPeteMusic — found at youtube.com/account_advanced

# Donations — override to change the link without a code deploy
NEXT_PUBLIC_DONATE_URL=https://square.link/u/MibuhN7B

# Internal deploy automation — shared secret for GitHub Actions → admin app calls (clear-stream-override etc.)
# Generate: openssl rand -hex 32 — must also be set as GitHub Secret INTERNAL_DEPLOY_SECRET
INTERNAL_DEPLOY_SECRET=your_internal_deploy_secret_here

# Live streaming — RTMP ingest + HLS delivery via MediaMTX on EC2
RTMP_STREAM_KEY=your_rtmp_stream_key_here   # Generate: openssl rand -hex 16 — must also be set as GitHub Secret RTMP_STREAM_KEY
HLS_STREAM_URL=https://hls.stpetemusic.live/live/index.m3u8   # Server-side HEAD check URL (override for local testing)
NEXT_PUBLIC_HLS_STREAM_URL=https://hls.stpetemusic.live/live/index.m3u8   # Client-side HLS player URL (override for local testing)

# CloudWatch alerting — email for SNS alarm notifications (EC2, RDS, RTMP, CloudFront)
# Default is theburgmusic@gmail.com. Override by setting TF_VAR_alert_email in GitHub Secrets (ALERT_EMAIL).
# TF_VAR_alert_email=theburgmusic@gmail.com
# n8n YouTube (same credentials — n8n uses the OAuth2 flow separately)
YOUTUBE_CLIENT_ID=your_youtube_client_id
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret

# PostgreSQL Database
POSTGRES_USER=stpetemusic
POSTGRES_PASSWORD=your_strong_postgres_password_here
# POSTGRES_HOST is set automatically by docker-compose (service name: postgres)
# DB encryption key — used by pgcrypto for column-level PII encryption
DB_ENCRYPTION_KEY=your_strong_encryption_key_here

# Notion Integration (optional, for future database connectivity)
NOTION_API_KEY=your_notion_api_key_here

# Linktree API (AWS Lambda — override to rotate without a code deploy)
LINKTREE_API_URL=https://qag1q0ijn5.execute-api.us-east-1.amazonaws.com/linktree

# Eventbrite — Admin only (theburgmusic@gmail.com)
# Get tokens from: https://www.eventbrite.com/platform/api-keys
EVENTBRITE_API_KEY=
EVENTBRITE_CLIENT_SECRET=
EVENTBRITE_PRIVATE_TOKEN=
EVENTBRITE_PUBLIC_TOKEN=

# Artist sheet sync — n8n cron → /api/internal/artists/upsert-from-sheet
# Generate with: openssl rand -base64 32
# Add to: .env (local), infrastructure/import-vars.tfvars (tofu), n8n EC2 .env
CRON_SECRET=

