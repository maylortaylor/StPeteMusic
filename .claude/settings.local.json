{
  "env": {
    "GH_CONFIG_DIR": "/workspace/.gh-config"
  },
  "permissions": {
    "allow": [
      "Bash(git fetch:*)",
      "Bash(git merge:*)",
      "Bash(git checkout:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(gh pr:*)",
      "Bash(gh run:*)",
      "Bash(npm install:*)",
      "Bash(npx next:*)",
      "Bash(git stash:*)",
      "Bash(npm list:*)",
      "Bash(node:*)",
      "Bash(grep:*)",
      "Bash(gh auth:*)",
      "Bash(git merge-tree:*)",
      "Bash(git pull:*)",
      "Bash(git remote:*)",
      "Bash(ls /workspace/StPeteMusic/*.md)",
      "Bash(git config:*)",
      "Bash(GH_CONFIG_DIR=/workspace/.gh-config gh auth:*)",
      "Bash(npm test:*)",
      "Bash(xargs ls:*)",
      "Bash(npm why:*)"
    ]
  }
}
