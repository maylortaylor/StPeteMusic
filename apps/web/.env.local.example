# On-demand revalidation secret (must match admin app's REVALIDATION_SECRET)
REVALIDATION_SECRET=change-me-to-a-random-string

# Listmonk newsletter API (local Docker)
LISTMONK_API_URL=http://localhost:9000
LISTMONK_USERNAME=admin
LISTMONK_PASSWORD=yourpassword
LISTMONK_LIST_ID=3

# Resend email service (for contact form, newsletters)
RESEND_API_KEY=re_your_api_key_here

# Google Tag Manager (production ID — already wired in layout.tsx)
NEXT_PUBLIC_GTM_ID=GTM-WW7MSP3L

# Payload CMS (Phase 2)
# NEXT_PUBLIC_PAYLOAD_API_URL=http://localhost:3001
# Google Analytics 4 (run npm run ga4:setup to discover these)
GA4_ACCOUNT_ID=your_ga4_account_id_here
GA4_PROPERTY_ID=535560580

REVALIDATION_SECRET=51013b360ff...

# Meta Pixel (Facebook/Instagram tracking)
NEXT_PUBLIC_META_PIXEL_ID=1015368770610756

# Meta Conversions API — server-side (never NEXT_PUBLIC)
FACEBOOK_PIXEL_ID=1015368770610756
FACEBOOK_SYSTEM_USER_TOKEN=your_system_user_token_here

# Microsoft Clarity (session recording + heatmaps)
# Create project at clarity.microsoft.com — paste Project ID here
NEXT_PUBLIC_CLARITY_ID=