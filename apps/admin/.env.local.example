# Database
DATABASE_URL=postgresql://stpetemusic:password@stpetemusic-postgres.cmnogyowgoe1.us-east-1.rds.amazonaws.com:5432/stpetemusic

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here
CLERK_WEBHOOK_SECRET=whsec_xxx

# App Config
NEXT_PUBLIC_SITE_URL=http://localhost:3001
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard

#
# Cloudflare DNS — required for cloudflare.tf to manage stpetemusic.live DNS records
#   1. Create API token: dash.cloudflare.com → My Profile → API Tokens → Create Token → "Edit zone DNS" template
#      Scope the token to Zone: stpetemusic.live only.
#   2. Get Zone ID: dash.cloudflare.com → stpetemusic.live → right sidebar → Zone ID
#   3. Add GitHub Secrets: CLOUDFLARE_API_TOKEN and CLOUDFLARE_ZONE_ID
#
#   export TF_VAR_cloudflare_api_token="..."   # CLOUDFLARE_API_TOKEN GitHub Secret
#   export TF_VAR_cloudflare_zone_id="..."     # CLOUDFLARE_ZONE_ID GitHub Secret
#
CLOUDFLARE_API_TOKEN=sdfsdfasd......
CLOUDFLARE_ZONE_ID=b1830470b....

#
# Google Cloud — required for gcp.tf / gcp-analytics.tf / gcp-n8n.tf
#   Auth: gcloud auth application-default login
#   Get org ID: gcloud organizations list → theburgmusic-org
#   Get project ID: gcloud projects list
#
#   export TF_VAR_google_org_id="..."               # TF_VAR_GOOGLE_ORG_ID GitHub Secret
#   export TF_VAR_google_project_id="..."           # TF_VAR_GOOGLE_PROJECT_ID GitHub Secret
#
TF_VAR_google_org_id=982527051911
TF_VAR_google_project_id=project-bb73c742-70e6-4419-a66