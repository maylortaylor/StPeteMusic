        "headerParameters": {
          "parameters": [
            {
              "name": "Accept",
              "value": "application/vnd.olrapi.note+json"
            }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1248,
        -80
      ],
      "id": "68dc8da6-676f-4641-9b51-b3253eeb2576",
      "name": "Query Obsidian Vault",
      "credentials": {
        "httpBearerAuth": {
          "id": "JG69xsJID8L4BlJr",
          "name": "Bearer Auth account"
        }
      }
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Parse the stringified data from Obsidian API\nconst parsed = JSON.parse($json.data);\nconst fm = parsed.frontmatter || {};\n\n// Only process posts with status 'ready'\nif (fm.status !== 'ready') {\n  return null;\n}\n\n// Return clean extracted data\nreturn {\n  filePath: parsed.path || '',\n  bandName: fm['band-name'] || '',\n  bandUsernameIG: fm['band-username-ig'] || '',\n  title: fm.title || '',\n  caption: fm.caption || '',\n  ytDescription: fm['yt-description'] || '',\n  platform: fm.platform || '',\n  postDate: (() => {\n    const raw = fm['publish-date'] || '';\n    if (!raw) return '';\n    // YouTube publishAt requires RFC 3339 with timezone\n    // St. Pete FL is Eastern: EDT (UTC-4) Mar-Nov, EST (UTC-5) Nov-Mar\n    const d = new Date(raw.replace(' ', 'T'));\n    return raw.replace(' ', 'T') + (d.getMonth() >= 2 && d.getMonth() <= 10 ? '-04:00' : '-05:00');\n  })(),\n    recordDate: (() => {\n    const raw = fm['record-date'] || '';\n    if (!raw) return '';\n    // YouTube recordDate requires RFC 3339 with timezone\n    // St. Pete FL is Eastern: EDT (UTC-4) Mar-Nov, EST (UTC-5) Nov-Mar\n    const d = new Date(raw.replace(' ', 'T'));\n    return raw.replace(' ', 'T') + (d.getMonth() >= 2 && d.getMonth() <= 10 ? '-04:00' : '-05:00');\n  })(),\n  youtubePlaylist: fm['yt-playlist'] || '',\n  youtubeTags: fm['yt-tags'] || '',\n  mediaUrl: fm['media-link'] || '',\n  mediaType: fm['media-type'] || '',\n  hashtags: fm.hashtags || '',\n  ytTags: fm['yt-tags'] || '',\n  mentions: fm.mentions || '',\n  privacyStatus: fm['privacy-status'] || 'unlisted',\n  status: fm.status,\n  aiGenerated: fm['ai-generated'] || false,\n  originalContent: parsed.content || ''\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1440,
        -80
      ],
      "id": "2800bd9d-143a-4fcd-8679-57b17b678101",
      "name": "Extract Post Data"
    },
    {
      "parameters": {
        "dataType": "string",
        "value1": "={{ $json.platform }}",
        "rules": {
          "rules": [
            {
              "value2": "YouTube"
            },
            {
              "operation": "notContains",
              "value2": "YT",
              "output": 1
            }
          ]
        }
      },
      "type": "n8n-nodes-base.switch",
      "typeVersion": 1,
      "position": [
        1648,
        -80
      ],
      "id": "7b70c26e-03dd-4ad8-ad72-20420198e347",
      "name": "Platform Check"
    },
    {
      "parameters": {
        "operation": "download",
        "fileId": {
          "__rl": true,
          "value": "={{ $('Extract Post Data').item.json.mediaUrl }}",
          "mode": "url"
        },
        "options": {}
      },
      "type": "n8n-nodes-base.googleDrive",
      "typeVersion": 3,
      "position": [
        1888,
        -288
      ],
      "id": "be7c5040-43a3-4f3b-8b54-b5309307b7b0",
      "name": "Download file",
      "credentials": {
        "googleDriveOAuth2Api": {
          "id": "puKV9r7d37Capu98",
          "name": "Google Drive account"
        }
      }
    },
    {
      "parameters": {
        "resource": "video",
        "operation": "upload",
        "title": "={{ $('Extract Post Data').item.json.caption }}",
        "regionCode": "US",
        "categoryId": "=10",
        "options": {
          "defaultLanguage": "es-US",
          "description": "={{ $('Extract Post Data').item.json.ytDescription }}",
          "embeddable": false,
          "license": "creativeCommon",
          "notifySubscribers": false,
          "privacyStatus": "private",
          "publicStatsViewable": true,
          "publishAt": "={{$json.postDate.slice(0,22)}}",
          "recordingDate": "={{$json.recordDate.slice(0,22)}}",
          "selfDeclaredMadeForKids": false,
          "tags": "={{ $('Extract Post Data').item.json.youtubeTags }}"
        }
      },
      "type": "n8n-nodes-base.youTube",
      "typeVersion": 1,
      "position": [
        2128,
        -288
      ],
      "id": "67981acf-8093-4d69-98c7-5cac801933d4",
      "name": "Upload a video",
      "credentials": {
        "youTubeOAuth2Api": {
          "id": "mTi24S9mwCIxSqWV",
          "name": "YouTube account"
        }
      }
    },
    {
      "parameters": {
        "resource": "playlistItem",
        "playlistId": "={{ $('Extract Post Data').item.json.youtubePlaylist }}",
        "videoId": "={{ $json.uploadId }}",
        "options": {}
      },
      "type": "n8n-nodes-base.youTube",
      "typeVersion": 1,
      "position": [
        2336,
        -288
      ],
      "id": "8d681ef7-c08c-4227-9c59-f78ce079d141",
      "name": "Add to Playlist",
      "credentials": {
        "youTubeOAuth2Api": {
          "id": "mTi24S9mwCIxSqWV",
          "name": "YouTube account"
        }
      }
    },
    {
      "parameters": {
        "url": "={{ $env.OBSIDIAN_HOST }}/vault/{{ $('Extract Post Data').item.json.filePath }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBearerAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Accept",
              "value": "text/markdown"
            }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2544,
        -288
      ],
      "id": "2d3a0056-4e0b-4521-b338-1b505b446336",
      "name": "Get Obsidian File Content",
      "credentials": {
        "httpBearerAuth": {
          "id": "JG69xsJID8L4BlJr",
          "name": "Bearer Auth account"
        }
      }
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Replace 'status: ready' with 'status: posted' in YAML frontmatter\nconst rawMarkdown = $json.body || $json.data || '';\nconst updated = rawMarkdown.replace(/^status: ready$/m, 'status: posted');\nreturn {\n  json: {\n    updatedContent: updated,\n    filePath: $('Extract Post Data').item.json.filePath\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2720,
        -288
      ],
      "id": "238b1023-db2a-443f-b7ed-d876f3f0386e",
      "name": "Build Updated Content"
    },
    {
      "parameters": {
        "method": "PUT",
        "url": "={{ $env.OBSIDIAN_HOST }}/vault/{{ $json.filePath }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBearerAuth",
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "text/html",
        "body": "={{ $json.updatedContent }}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2928,
