      "id": "13a69029-9e47-4f10-919b-3fdd207c0940",
      "name": "Update Obsidian Status",
      "credentials": {
        "httpBearerAuth": {
          "id": "JG69xsJID8L4BlJr",
          "name": "Bearer Auth account"
        }
      }
    }
