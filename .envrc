# direnv configuration for StPeteMusic project
# Auto-loads environment when you cd into this directory
# See: https://direnv.net/

# Unset problematic global vars that might leak from PSD/amver projects
unset AWS_WEB_IDENTITY_TOKEN_FILE
unset NEXT_PUBLIC_AMVER_SERVICE_URL
unset DATABASE_URL
unset KEYCLOAK_ISSUER

# Set AWS profile for this project
export AWS_PROFILE=personal

# Load local .env file if it exists (git-ignored, contains secrets)
dotenv_if_exists .env

# Unset app-specific Clerk keys AFTER loading .env so each app reads its own .env.local
# (root .env sets these for apps/web; leaving them set causes apps/admin
# to pick up the wrong Clerk instance and fail auth with 401)
unset CLERK_SECRET_KEY
unset NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY

# Notify user that direnv is active
echo "✓ StPeteMusic environment loaded (AWS_PROFILE=personal)"
